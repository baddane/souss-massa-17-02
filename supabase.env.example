# ===============================================
# VARIABLES D'ENVIRONNEMENT SUPABASE
# Copier ce fichier en .env.local et remplir vos vraies valeurs
# Ne jamais commiter le fichier .env.local
# ===============================================

# -----------------------------------------------
# COMPTE SUPABASE 1 — BASE DE DONNÉES DU SITE
# Authentification, profils candidats, profils entreprises,
# candidatures, notifications, offres publiées par les entreprises
# -----------------------------------------------
VITE_SUPABASE_URL=https://VOTRE_REF_SITE.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...VOTRE_CLE_SITE

# -----------------------------------------------
# COMPTE SUPABASE 2 — BASE DE DONNÉES DES OFFRES
# Offres d'emploi externes, Entreprises (annuaire),
# Écoles (annuaire), Conseils, Blog
# -----------------------------------------------
VITE_SUPABASE_OFFERS_URL=https://VOTRE_REF_OFFRES.supabase.co
VITE_SUPABASE_OFFERS_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...VOTRE_CLE_OFFRES

# -----------------------------------------------
# GOOGLE GEMINI API (parsing CV et documents)
# Obtenir sur https://aistudio.google.com/
# -----------------------------------------------
VITE_GEMINI_API_KEY=votre_cle_gemini_ici

# -----------------------------------------------
# ENVIRONNEMENT
# -----------------------------------------------
NODE_ENV=development

# ===============================================
# TABLEAU RÉCAPITULATIF DES RESPONSABILITÉS
# ===============================================
#
# COMPTE SITE (VITE_SUPABASE_URL)             | COMPTE OFFRES (VITE_SUPABASE_OFFERS_URL)
# --------------------------------------------|------------------------------------------
# auth.users (authentification)               | job_offers (offres externes)
# student_profiles (profils candidats)        | companies (annuaire entreprises)
# company_profiles (profils entreprises)      | schools (annuaire écoles)
# applications (candidatures)                 | advice_categories & advice_articles
# notifications                               | blog_categories & blog_posts
# job_offers (publiées par les entreprises)   |
#
# ===============================================
# COMMENT OBTENIR VOS CLÉS SUPABASE
# ===============================================
#
# 1. Connectez-vous sur https://supabase.com
# 2. Ouvrez votre projet (répétez pour chaque projet)
# 3. Allez dans Settings > API
# 4. Copiez :
#    - Project URL  → VITE_SUPABASE_URL (ou VITE_SUPABASE_OFFERS_URL)
#    - anon public  → VITE_SUPABASE_ANON_KEY (ou VITE_SUPABASE_OFFERS_ANON_KEY)
#
# ===============================================
# BUCKETS STORAGE À CRÉER (compte Site uniquement)
# ===============================================
#
# - cv-files        : CVs des candidats
# - company-logos   : Logos des entreprises
# - company-docs    : Documents officiels entreprises
#
# ===============================================
# SCHÉMAS SQL À APPLIQUER
# ===============================================
#
# Compte Site    → exécuter : supabase_schema.sql + supabase/migrations/
# Compte Offres  → tables : job_offers, companies, schools,
#                           advice_categories, advice_articles,
#                           blog_categories, blog_posts
#
# ===============================================
# CONFIGURATION AUTH (compte Site)
# ===============================================
#
# Authentication > URL Configuration :
# Site URL         : https://souss-massa-17-02-git-main-rbaddane-1385s-projects.vercel.app
# Redirect URLs    : https://souss-massa-17-02-git-main-rbaddane-1385s-projects.vercel.app/**
#
# ⚠️  NE PAS mettre localhost ici — c'est le projet en production sur Vercel
# Pour le développement local, ajouter aussi :
#   http://localhost:5173/**  (en 2ème ligne dans Redirect URLs)
#
# ===============================================
